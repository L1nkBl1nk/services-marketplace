# Server configuration — copy to .env and fill in
PORT=5000

# PostgreSQL
DB_NAME=marketplace
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
# Set to true for managed Postgres (Neon, Render) which require SSL
DB_SSL=false

# Auth
SECRET_KEY=your_secret_key

# Stripe (use TEST keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx

# Where the React client runs (used for Stripe success/cancel redirects)
CLIENT_URL=http://localhost:5173

# Public URL of THIS server (optional) — enables product images in Stripe Checkout
# SERVER_URL=http://localhost:5000

# Cloudinary — durable image storage (from cloudinary.com dashboard).
# If set, product images upload to Cloudinary; otherwise they save to local /static.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret